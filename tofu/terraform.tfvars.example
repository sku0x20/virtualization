proxmox_endpoint  = "https://192.168.1.x:8006/"
proxmox_api_token = "root@pam!tofu=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_node      = "pve"
storage           = "local-lvm"
# image must already exist on Proxmox — copy it to /var/lib/vz/template/iso/ first
alpine_image_id   = "local:iso/alpine-cloud.qcow2"
# openssl rand -hex 32
k3s_token         = "your-secret-token"
